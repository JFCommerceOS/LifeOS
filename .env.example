# PostgreSQL — matches docker-compose.yml local dev defaults:
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/lifeos"
# CI (GitHub Actions) uses the same URL against the workflow Postgres service — no extra file needed there.

# API server
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Node
NODE_ENV=development

# --- Local LLM (optional; Life OS runs without these) ---
# Ollama: https://ollama.com — Tier 2 general assistance (e.g. brief item explain).
OLLAMA_BASE_URL=http://127.0.0.1:11434
LLM_TIER2_MODEL=qwen2.5:7b
LLM_ENABLED=false
# OLLAMA_TIMEOUT_MS=45000

# A-S-FLC sidecar (Python): apps/asflc-sidecar — Tier 1 policy guard + optional /decide.
ASFLC_SIDECAR_URL=http://127.0.0.1:8100
ASFLC_OLLAMA_MODEL=asflc-decision
ASFLC_ENABLED=false
# ASFLC_TIMEOUT_MS=30000
