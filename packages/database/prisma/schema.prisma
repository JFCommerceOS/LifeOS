  updatedAt                DateTime @updatedAt
}

// --- Signal Intake + Context Engine (blueprint: raw → signal → normalized → facts → context) ---

enum SignalType {
  NOTE_CAPTURE
  CALENDAR_EVENT
  TASK_ITEM
  DOCUMENT_INPUT
  REMINDER_INPUT
  CORRECTION_INPUT
  ROUTINE_GOAL
  PLACE_EVENT
  SCREEN_TIME_SUMMARY
  VOICE_CAPTURE
  RELATIONSHIP_SIGNAL
  LANGUAGE_PREFERENCE_SIGNAL
  SURFACE_INTERACTION_SIGNAL
  /// Sprint 08 — email headers/snippet metadata only (no full body by default)
  EMAIL_THREAD_METADATA
  /// Sprint 12 — voice transcript routed like other captures
  VOICE_NOTE
}

enum SignalSourceType {
  manual
  connector
  voice
  system
  api
}

enum SignalProcessingStatus {
  pending
  normalizing
  extracting
  resolving
  context_ready
  failed
}

enum SignalProcessingStage {
  intake
  normalization
  extraction
  entity_resolution
  context_construction
  evidence
}

enum ContextObjectType {
  EVENT_CONTEXT
  PERSON_CONTEXT
  OBLIGATION_CONTEXT
  ROUTINE_CONTEXT
  GEO_CONTEXT
  RELATIONSHIP_CONTEXT
  SURFACE_CONTEXT
  USER_STATE_CONTEXT
}

model SignalEnvelope {
  id                String                 @id @default(cuid())
  userId            String
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  signalType        SignalType
  sourceType        SignalSourceType
  sourceConnectorId String?
  sourceConnector   SourceConnector?       @relation(fields: [sourceConnectorId], references: [id], onDelete: SetNull)
  sourceRecordId    String?
  sourceRecord      SourceRecord?          @relation(fields: [sourceRecordId], references: [id], onDelete: SetNull)
  rawPayloadJson    String
  contentHash       String
  occurredAt        DateTime?
  receivedAt        DateTime               @default(now())
  languageCode      String?                @default("en")
  privacyClass      String?                @default("medium")
  trustLevel        Int                    @default(50)
  processingStatus  SignalProcessingStatus @default(pending)

  normalizedRecord    NormalizedSignalRecord?
  extractedFacts      ExtractedFact[]
  processingLogs      SignalProcessingLog[]
  memoryEvidenceLinks MemoryEvidenceLink[]
  sourceObligations   Obligation[]            @relation("ObligationFromSignal")
  evidenceFromSignal  EvidenceItem[]          @relation("EvidenceItemFromSignal")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, receivedAt])
  @@index([userId, processingStatus])
  @@index([contentHash])
}

model NormalizedSignalRecord {
  id                             String         @id @default(cuid())
  signalId                       String         @unique
  signal                         SignalEnvelope @relation(fields: [signalId], references: [id], onDelete: Cascade)
  normalizedText                 String         @default("")
  normalizedTimeJson             String         @default("{}")
  candidatePeopleJson            String         @default("[]")
  candidatePlaceJson             String         @default("{}")
  candidateTopicsJson            String         @default("[]")
  candidateTasksJson             String         @default("[]")
  candidateDeadlinesJson         String         @default("[]")
  candidateRelationshipHintsJson String         @default("[]")
  candidateRoutineHintsJson      String         @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExtractedFact {
  id                  String         @id @default(cuid())
  signalId            String
  signal              SignalEnvelope @relation(fields: [signalId], references: [id], onDelete: Cascade)
  factType            String
  factValueJson       String         @default("{}")
  confidence          Float          @default(0.5)
  observedVsExtracted String         @default("extracted")
  evidenceExcerpt     String?

  transcriptSegmentId String?
  transcriptSegment   TranscriptSegment? @relation(fields: [transcriptSegmentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  memoryEvidenceLinks MemoryEvidenceLink[]
  evidenceItems       EvidenceItem[]

  @@index([signalId])
  @@index([factType])
  @@index([transcriptSegmentId])
}

model ContextObject {
  id               String            @id @default(cuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  contextType      ContextObjectType
  linkedEntityType String
  linkedEntityId   String
  summaryJson      String            @default("{}")
  confidence       Float             @default(0.7)
  freshnessScore   Float             @default(1.0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, contextType])
  @@index([linkedEntityType, linkedEntityId])
}

model SignalProcessingLog {
  id        String                @id @default(cuid())
  signalId  String
  signal    SignalEnvelope        @relation(fields: [signalId], references: [id], onDelete: Cascade)
  stage     SignalProcessingStage
  status    String
  summary   String?
  errorCode String?

  createdAt DateTime @default(now())

  @@index([signalId, createdAt])
}

// --- Memory Graph + Personal Continuity Store ---

enum MemoryNodeType {
  PERSON
  EVENT
  OBLIGATION
  TASK
  NOTE
  DOCUMENT
  PROJECT
  ROUTINE
  PLACE
  DECISION
  PREFERENCE
  SUGGESTION
}

enum MemoryLayerType {
  hot_operational
  warm_episodic
  semantic
  evidence
  cold_archive
}

enum MemoryEdgeType {
  related_to
  caused_by
  involves
  supports
  derived_from
  repeats_with
  depends_on
  follows_up_from
}

model MemoryNode {
  id               String          @id @default(cuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  nodeType         MemoryNodeType
  summary          String
  confidence       Float           @default(0.5)
  strengthScore    Float           @default(0.5)
  layerType        MemoryLayerType @default(evidence)
  sensitivityClass String          @default("medium")
  lastAccessedAt   DateTime?
  lastConfirmedAt  DateTime?
  decayRate        Float           @default(0.01)
  refEntityType    String?
  refEntityId      String?
  archivedAt       DateTime?

  status          String    @default("active")
  lastObservedAt  DateTime?
  lastDismissedAt DateTime?
  lastResolvedAt  DateTime?

  edgesOut       MemoryEdge[]          @relation("MemoryEdgeFrom")
  edgesIn        MemoryEdge[]          @relation("MemoryEdgeTo")
  evidenceLinks  MemoryEvidenceLink[]
  confirmations  MemoryConfirmation[]
  archiveRecords MemoryArchiveRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, layerType])
  @@index([userId, nodeType])
  @@index([userId, archivedAt])
  @@index([refEntityType, refEntityId])
}

model MemoryEdge {
  id            String         @id @default(cuid())
  fromNodeId    String
  toNodeId      String
  fromNode      MemoryNode     @relation("MemoryEdgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode        MemoryNode     @relation("MemoryEdgeTo", fields: [toNodeId], references: [id], onDelete: Cascade)
  edgeType      MemoryEdgeType
  strength      Float          @default(0.5)
  active        Boolean        @default(true)
  evidenceCount Int            @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fromNodeId])
  @@index([toNodeId])
}

model MemoryEvidenceLink {
  id              String          @id @default(cuid())
  memoryNodeId    String
  memoryNode      MemoryNode      @relation(fields: [memoryNodeId], references: [id], onDelete: Cascade)
  signalId        String?
  signal          SignalEnvelope? @relation(fields: [signalId], references: [id], onDelete: Cascade)
  extractedFactId String?
  extractedFact   ExtractedFact?  @relation(fields: [extractedFactId], references: [id], onDelete: Cascade)
  excerpt         String?

  createdAt DateTime @default(now())

  @@index([memoryNodeId])
  @@index([signalId])
  @@index([extractedFactId])
}

model MemoryConfirmation {
  id              String     @id @default(cuid())
  memoryNodeId    String
  memoryNode      MemoryNode @relation(fields: [memoryNodeId], references: [id], onDelete: Cascade)
  confirmedByUser Boolean    @default(false)
  corrected       Boolean    @default(false)
  correctionNote  String?

  createdAt DateTime @default(now())

  @@index([memoryNodeId])
}

model MemoryDecayRule {
  id                      String         @id @default(cuid())
  nodeType                MemoryNodeType @unique
  decayRate               Float
  inactivityThresholdDays Int
  archiveThresholdDays    Int
}

model MemoryArchiveRecord {
  id           String     @id @default(cuid())
  memoryNodeId String
  memoryNode   MemoryNode @relation(fields: [memoryNodeId], references: [id], onDelete: Cascade)
  archivedAt   DateTime   @default(now())
  reason       String?

  @@index([memoryNodeId])
}

// --- Sprint 09 — Privacy, retention, purge controls ---

enum RetentionClass {
  HOT_ACTIVE
  WARM_CONTINUITY
  SEMANTIC_LONG_LIFE
  EVIDENCE_SHORT_LIFE
  SENSITIVE_RESTRICTED
  EXPORTED_PENDING_DELETION
  PURGE_QUEUED
  TOMBSTONED
}

enum DataSensitivityLevel {
  NORMAL
  ELEVATED
  SENSITIVE
  HIGHLY_SENSITIVE
}

enum PrivacyActionType {
  EXPORT
  DELETE
  ARCHIVE
  REDACT
  PURGE_CONNECTOR
  PURGE_CATEGORY
  DISCONNECT_AND_PURGE
  RETENTION_CHANGE
}

enum PrivacyActionStatus {
  REQUESTED
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  PARTIAL
  CANCELLED
}

enum PurgeExecutionMode {
  SOFT_DELETE
  HARD_DELETE_WHERE_SUPPORTED
  REDACT_AND_KEEP_SHAPE
  DISCONNECT_ONLY
}

enum ExportFormat {
  json
  markdown
}

enum ExportJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum PurgeJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  PARTIAL
}

model DataRetentionPolicy {
  id                       String               @id @default(cuid())
  userId                   String
  user                     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  category                 String
  sensitivityLevel         DataSensitivityLevel @default(NORMAL)
  retentionClass           RetentionClass       @default(WARM_CONTINUITY)
  defaultActionAfterWindow String               @default("none")
  retentionDays            Int?
  autoPurgeEnabled         Boolean              @default(false)
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt

  @@unique([userId, category])
  @@index([userId])
}

model PrivacyAction {
  id               String              @id @default(cuid())
  userId           String
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  actionType       PrivacyActionType
  targetEntityType String
  targetEntityId   String?
  reason           String?
  requestedAt      DateTime            @default(now())
  executedAt       DateTime?
  status           PrivacyActionStatus @default(REQUESTED)
  summaryJson      String              @default("{}")
  createdAt        DateTime            @default(now())

  @@index([userId, createdAt])
  @@index([userId, status])
}

model PurgeJob {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  scopeType       String
  scopeId         String?
  category        String
  executionMode   PurgeExecutionMode
  status          PurgeJobStatus     @default(QUEUED)
  queuedAt        DateTime           @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  resultJson      String             @default("{}")
  createdAt       DateTime           @default(now())

  @@index([userId, createdAt])
}

enum ExportEncryptionMode {
  NONE
  AES256_GCM_DEV
}

model ExportJob {
  id                String          @id @default(cuid())
  userId            String
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  exportScope       String          @default("standard")
  includeSensitive  Boolean         @default(false)
  format            ExportFormat    @default(json)
  status            ExportJobStatus @default(QUEUED)
  filePath          String?
  exportPayloadJson String?
  expiresAt         DateTime?
  /// Hardening Sprint 01 — NONE = plain JSON in DB; AES256_GCM_DEV = ciphertext envelope (dev key)
  encryptionMode    ExportEncryptionMode @default(NONE)
  downloadedAt      DateTime?
  createdAt         DateTime        @default(now())
  completedAt       DateTime?

  @@index([userId, createdAt])
}

model RedactionRule {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  String
  fieldPath String
  ruleType  String
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, category])
}

model StorageInventorySnapshot {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshotJson String
  generatedAt  DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([userId, generatedAt])
}

// --- Sprint 10 — Mobile runtime + notification surface (starter pack §8–9) ---

enum NotificationSurfaceKind {
  DO_NOW
  DO_TODAY
  BEFORE_NEXT_EVENT
  ADMIN_DUE
  DOCUMENT_REVIEW
  MEMORY_CONFIRMATION
  CONTEXT_PREP
  DIGEST
}

enum NotificationUrgencyLevel {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum NotificationPrivacyLevel {
  GENERIC
  REDACTED
  SENSITIVE
}

enum NotificationDeliveryChannel {
  IN_APP
  LOCAL_PUSH
  PUSH
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  OPENED
  ACTED_ON
  SUPPRESSED
  FAILED
}

enum NotificationActionKind {
  OPEN
  CONFIRM
  DISMISS
  RESOLVE
  SNOOZE
  MUTE_CATEGORY
  OPEN_DETAIL
  OPEN_EVIDENCE
}

enum NotificationLockScreenMode {
  private_default
  redacted_reason
  full_detail
}

model NotificationSurfaceEvent {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  linkedEntityType String
  linkedEntityId   String

  sourceSuggestionId String?
  sourceSuggestion   Suggestion? @relation(fields: [sourceSuggestionId], references: [id], onDelete: SetNull)

  sourceMediationLogId String?
  sourceMediationLog   AssistantMediationLog? @relation(fields: [sourceMediationLogId], references: [id], onDelete: SetNull)

  notificationType NotificationSurfaceKind
  title            String
  bodySummary      String?
  reasonSummary    String?
  urgencyLevel     NotificationUrgencyLevel     @default(NORMAL)
  privacyLevel     NotificationPrivacyLevel     @default(REDACTED)
  deliveryChannel  NotificationDeliveryChannel @default(IN_APP)
  deliveryStatus   NotificationDeliveryStatus   @default(PENDING)

  sentAt   DateTime?
  openedAt DateTime?
  actedAt  DateTime?

  /// When set, duplicate sends for the same entity + type are skipped until this window passes.
  dedupeKey String?

  createdAt DateTime @default(now())

  actionLogs NotificationActionLog[]

  @@index([userId, createdAt])
  @@index([userId, linkedEntityType, linkedEntityId])
  @@index([userId, deliveryStatus])
  @@index([sourceMediationLogId])

  policyDecision PolicyDecision?
}

/// Hardening Phase A — auditable allow/deny for automated actions (first surface: notification delivery).
enum PolicySurfaceKind {
  notification_delivery
}

enum PolicyOutcome {
  allow
  deny
}

model PolicyDecision {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  surface PolicySurfaceKind
  outcome PolicyOutcome
  /// Machine-readable codes, e.g. category_disabled, mediation_blocked, dedupe_suppressed
  reasonCodes Json @default("[]")
  context     Json?

  refEntityType String?
  refEntityId   String?

  notificationSurfaceEventId String? @unique
  notificationSurfaceEvent   NotificationSurfaceEvent? @relation(fields: [notificationSurfaceEventId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId, surface, createdAt])
}

model NotificationUserPreference {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  lockScreenMode NotificationLockScreenMode @default(private_default)

  quietHoursEnabled Boolean @default(false)
  quietHoursStart   String? /// "HH:mm" local to user timezone
  quietHoursEnd     String?

  criticalOverrideEnabled Boolean @default(true)

  doNowEnabled             Boolean @default(true)
  doTodayEnabled           Boolean @default(true)
  beforeNextEventEnabled   Boolean @default(true)
  adminAlertsEnabled       Boolean @default(true)
  documentAlertsEnabled    Boolean @default(true)
  studyAlertsEnabled       Boolean @default(true)
  healthAlertsEnabled      Boolean @default(true)
  digestEnabled            Boolean @default(false)
  digestTime               String? /// "HH:mm"

  /// Sprint 11 — optional preferred delivery window (local HH:mm); calm vs direct copy
  preferredReminderWindowStart String?
  preferredReminderWindowEnd   String?
  notificationVerbosity        NotificationVerbosity @default(calm)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotificationDeviceRegistration {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  deviceType       String /// phone, watch, web
  appRuntimeType   String /// web, pwa, native_stub
  pushTokenOrLocalDeviceKey String?
  isActive         Boolean  @default(true)
  lastSeenAt       DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
}

model NotificationActionLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  notificationEventId String
  notificationEvent   NotificationSurfaceEvent @relation(fields: [notificationEventId], references: [id], onDelete: Cascade)

  actionType NotificationActionKind
  note       String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([notificationEventId])
}

// --- Sprint 11 — User Profile & Priority adaptation (UPR) ---

model UserProfileMode {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  activeMode         MainLifeMode
  sourceType         String /// manual | inferred | context
  sourceEntityType   String?
  sourceEntityId     String?
  startsAt           DateTime  @default(now())
  endsAt             DateTime?
  confidence         Float     @default(0.7)

  createdAt DateTime @default(now())

  @@index([userId, startsAt])
  @@index([userId, sourceType])
}

model PreferenceInferenceSignal {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  signalType        String
  linkedEntityType  String?
  linkedEntityId    String?
  signalValueJson   String @default("{}")

  observedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId, signalType, observedAt])
}

model InferredPreferenceState {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  preferenceKey    String
  inferredValueJson String                 @default("{}")
  confidence       Float                  @default(0.5)
  reasonSummary    String?
  status           InferredPreferenceStatus @default(active)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, preferenceKey, status])
}

model PriorityProfileSnapshot {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  activeMode          MainLifeMode
  rankingWeightsJson  String @default("{}")
  triggerReason      String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model AdaptationDecisionLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  targetSurface     String
  linkedEntityType  String?
  linkedEntityId    String?
  adaptationType    String
  beforeValueJson   String @default("{}")
  afterValueJson    String @default("{}")
  reasonSummary     String?
  confidence        Float  @default(0.5)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, adaptationType])
}

// --- Hardening Sprint 02 — sync substrate, jobs, observability ---

enum SyncOutboxStatus {
  PENDING
  LEASED
  APPLIED
  FAILED
  BLOCKED_CONFLICT
  SUPPRESSED
}

enum ScheduledJobStatus {
  PENDING
  CLAIMED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  SUPPRESSED
}

enum JobRunStatus {
  STARTED
  SUCCEEDED
  FAILED
  SKIPPED
}

model MutationLog {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId       String?
  device         EdgeDevice?  @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  actorType      String
  entityType     String
  entityId       String
  mutationType   String
  payloadJson    Json         @default("{}")
  baseVersion    Int          @default(0)
  newVersion     Int          @default(1)
  causalGroupId  String?
  createdAt      DateTime     @default(now())

  syncOutbox     SyncOutbox?
  entityVersions EntityVersion[] @relation("EntityVersionMutation")

  @@index([userId, createdAt])
  @@index([userId, entityType, entityId])
}

model SyncOutbox {
  id           String            @id @default(cuid())
  mutationId   String            @unique
  mutation     MutationLog       @relation(fields: [mutationId], references: [id], onDelete: Cascade)
  targetScope  String
  syncStatus   SyncOutboxStatus  @default(PENDING)
  retryCount   Int               @default(0)
  nextRetryAt  DateTime?
  lastError    String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([syncStatus, nextRetryAt])
}

model EntityVersion {
  id                   String       @id @default(cuid())
  userId               String
  user                 User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityType           String
  entityId             String
  currentVersion       Int          @default(1)
  updatedByMutationId  String?
  updatedByMutation    MutationLog? @relation("EntityVersionMutation", fields: [updatedByMutationId], references: [id], onDelete: SetNull)
  updatedAt            DateTime     @default(now())

  @@unique([userId, entityType, entityId])
  @@index([userId, updatedAt])
}

model ConflictEvent {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityType           String
  entityId             String
  localMutationId      String
  competingMutationId  String
  resolutionType       String
  resolutionSummary    String
  humanReviewRequired  Boolean  @default(false)
  createdAt            DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, entityType, entityId])
}

model ScheduledJob {
  id                String             @id @default(cuid())
  jobType           String
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedEntityType  String?
  linkedEntityId    String?
  priority          Int                @default(0)
  scheduledFor      DateTime
  leaseOwner        String?
  leaseExpiresAt    DateTime?
  status            ScheduledJobStatus @default(PENDING)
  dedupeKey         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  runs JobRun[]

  @@index([userId, status, scheduledFor])
  @@index([userId, dedupeKey])
}

model JobRun {
  id             String        @id @default(cuid())
  jobId          String
  job            ScheduledJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  workerName     String
  runStatus      JobRunStatus
  startedAt      DateTime      @default(now())
  finishedAt     DateTime?
  errorSummary   String?
  outputSummary  String?

  @@index([jobId, startedAt])
}

model TraceEvent {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  traceType      String
  stage          String
  entityType     String?
  entityId       String?
  sourceRef      String?
  inputSummary   String?
  outputSummary  String?
  status         String
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, entityType, entityId])
}

model ExplanationEvent {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  surfacedEntityType   String
  surfacedEntityId     String
  reasonType           String
  explanationJson      Json     @default("{}")
  evidenceRefsJson     Json     @default("[]")
  confidence           Float    @default(0.5)
  createdAt            DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, surfacedEntityType, surfacedEntityId])
}

model ProjectionRefresh {
  id               String    @id @default(cuid())
  projectionType   String
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  triggerType      String
  triggerRef       String?
  refreshStatus    String
  createdAt        DateTime  @default(now())
  completedAt      DateTime?

  @@index([userId, createdAt])
  @@index([userId, projectionType])
}
